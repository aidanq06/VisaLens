# HuggingFace Inference API token (optional — extraction falls back to rules)
# Get yours at https://huggingface.co/settings/tokens
HF_API_TOKEN=your_huggingface_token_here

# InternRadar: Discord webhook for red/yellow alerts (optional)
# Channel settings -> Integrations -> Webhooks -> New Webhook
DISCORD_WEBHOOK_URL=

# InternRadar: SQLite location (optional, defaults to backend/radar.db)
# RADAR_DB_PATH=./radar.db
